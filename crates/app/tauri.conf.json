{
  "productName": "Tazama",
  "version": "2026.3.18-2",
  "identifier": "com.anomalyco.tazama",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../../ui && npm run dev",
    "beforeBuildCommand": "cd ../../ui && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Tazama",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "dialog": {
      "all": true
    },
    "fs": {
      "scope": ["**"]
    },
    "shell": {
      "open": true
    }
  }
}
